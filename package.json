{
  "name": "history_cv_tool",
  "version": "0.1.0",
  "private": true,
  "description": "本机历史粘贴板",
  "author": "history_cv_tool",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:next": "next build",
    "start": "next start",
    "dev:app": "concurrently -k \"next dev\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "dist": "npm run build:next && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win nsis"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.historycvtool.app",
    "productName": "历史粘贴板",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "历史粘贴板"
    }
  }
}
